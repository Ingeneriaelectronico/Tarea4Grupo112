# EXCEPCIONES PERSONALIZADAS
class SistemaError(Exception):       # Clase base para errores del sistema.
    pass

class ClienteError(SistemaError):    # Error específico para clientes.
    pass

class ServicioError(SistemaError):   # Error específico para servicios.
    pass

class ReservaError(SistemaError):    # Error específico para reservas.
    pass

# CLASE ABSTRACTA BASE
class Entidad(ABC):           # Clase abstracta que sirve como modelo general.
    def __init__(self, id):
        self._id = id         # Identificador único de la entidad.

    @abstractmethod
    def mostrar_info(self):   # Método abstracto que obliga a las clases hijas a implementarlo.
        pass

#------Parte 3 Hernan -----

# CLIENTE
class Cliente(Entidad):          # Clase Clienteh hereda de Entidad.
    def __init__(self, id, nombre, email):
        super().__init__(id)     # Llama al constructor de Entidad.
        self.nombre = nombre     # Usa el setter (validación automática) de nombre.
        self.email = email       # Usa el setter (validación automática) de email.

    @property
    def nombre(self):            # Metodo de nombre.
        return self._nombre

    @nombre.setter
    def nombre(self, valor):     # Setter con validación.
        if not valor or len(valor) < 3:
            raise ClienteError("Nombre inválido")
        self._nombre = valor

    @property
    def email(self):             # Getter de email.
        return self._email

    @email.setter
    def email(self, valor):      # Setter con validación.
        if "@" not in valor:
            raise ClienteError("Email inválido")
        self._email = valor

    def mostrar_info(self):      # Implementación del método abstracto.
        return f"Cliente: {self.nombre} - {self.email}"

