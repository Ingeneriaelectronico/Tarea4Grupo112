# CLIENTE
class Cliente(Entidad):          # Clase Clienteh hereda de Entidad.
    def __init__(self, id, nombre, email):
        super().__init__(id)     # Llama al constructor de Entidad.
        self.nombre = nombre     # Usa el setter (validación automática) de nombre.
        self.email = email       # Usa el setter (validación automática) de email.

    @property
    def nombre(self):            # Metodo de nombre.
        return self._nombre

    @nombre.setter
    def nombre(self, valor):     # Setter con validación.
        if not valor or len(valor) < 3:
            raise ClienteError("Nombre inválido")
        self._nombre = valor

    @property
    def email(self):             # Getter de email.
        return self._email

    @email.setter
    def email(self, valor):      # Setter con validación.
        if "@" not in valor:
            raise ClienteError("Email inválido")
        self._email = valor

    def mostrar_info(self):      # Implementación del método abstracto.
        return f"Cliente: {self.nombre} - {self.email}"
